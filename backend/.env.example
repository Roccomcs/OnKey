# ============================================================
#  OnKey Backend — Configuración de Entorno
# ============================================================

# ─── BASE DE DATOS ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inmobiliaria

# Tamaño del pool de conexiones MySQL (default: 10)
DATABASE_POOL_SIZE=10

# ─── AUTENTICACIÓN & SEGURIDAD ─────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Tiempo de expiración del JWT (default: 7d)
JWT_EXPIRY=7d

# Rounds para bcrypt (default: 10, rango: 8-15)
SALT_ROUNDS=10

# ─── MERCADOPAGO (PAGOS) ────────────────────────────────────
# Obtener en https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=

# Secret para validar webhooks de MercadoPago
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app/[APP_ID]/webhooks
MP_WEBHOOK_SECRET=

# ─── EMAIL (SMTP) ───────────────────────────────────────────
# Configuración para Google Gmail con App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── FRONTEND ───────────────────────────────────────────────
# URL donde corre el frontend (para CORS, emails, etc)
FRONTEND_URL=http://localhost:5173

# ─── SERVIDOR ───────────────────────────────────────────────
# Entorno: development, staging, production
NODE_ENV=development

# Puerto donde escucha la API (default: 3001)
PORT=3001

# Nivel de logging: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ─── RATE LIMITING ──────────────────────────────────────────
# Ventana de tiempo en milisegundos para rate limiting (default: 900000 = 15 min)
RATE_LIMIT_WINDOW=900000

# Máximo de requests por IP en la ventana (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ─── OPCIONAL ───────────────────────────────────────────────
# Google OAuth Client ID para validación de tokens (si aplica)
GOOGLE_CLIENT_ID=

# Versión de API para logging y debugging
API_VERSION=1.0.0