# ============================================================
#  OnKey Frontend — Configuración de Entorno
# ============================================================

# URL base de la API backend
# En desarrollo: usa el proxy de Vite (/api)
# En producción: debe ser la URL completa del backend
VITE_API_URL=https://onkey-production.up.railway.app/api

# Google OAuth Client ID para login con Google
# Obtener en: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=

# Nivel de logging (debug, info, warn, error)
VITE_LOG_LEVEL=info

# Versión de la app
VITE_APP_VERSION=1.0.0

# Feature flags
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_ADVANCED_REPORTS=true
